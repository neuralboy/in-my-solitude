# Required Environment Variables for In My Solitude Library

# --- Supabase Configuration ---
# Your Supabase Project URL (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Your Supabase Anonymous Key (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Your Supabase Service Role Key (Project Settings -> API) - Keep this server-side only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Email Configuration (Resend) ---
# Your Resend API Key (Resend Dashboard -> API Keys)
RESEND_API_KEY=re_your_resend_api_key

# The email address that will receive admin notifications
ADMIN_EMAIL=curator@example.com

# --- Site Configuration ---
# The canonical URL of your deployed site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
